# ============================================
# NextWave CRM — MCP Server Configuration
# Copie para .env e preencha os valores
# ============================================

# ── Servidor ────────────────────────────────
MCP_PORT=3001
MCP_BIND_ADDRESS=127.0.0.1
# Use 0.0.0.0 para aceitar conexões de rede (requer MCP_ALLOWED_IPS configurado)

# ── Autenticação ────────────────────────────
# Gere uma chave forte com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MCP_API_KEY=TROQUE-POR-UMA-CHAVE-FORTE

# ── IP Whitelist ────────────────────────────
# Separados por vírgula. Suporta IPs individuais e ranges CIDR.
# Exemplos:
#   127.0.0.1                     — Apenas localhost
#   127.0.0.1,192.168.1.0/24     — Localhost + rede local
#   *                             — Todos (NÃO RECOMENDADO em produção)
MCP_ALLOWED_IPS=127.0.0.1

# ── Origin Validation ──────────────────────
# Origens permitidas (header Origin). Use * para desabilitar validação.
MCP_ALLOWED_ORIGINS=*

# ── Rate Limiting ──────────────────────────
MCP_RATE_LIMIT=100
MCP_RATE_WINDOW=60

# ── Logging ────────────────────────────────
# Níveis: debug, info, warn, error
MCP_LOG_LEVEL=info

# ── Banco de Dados ─────────────────────────
# Caminho relativo ao diretório mcp-server/
# Banco de dados PostgreSQL (conecte ao mesmo banco do CRM)
DATABASE_URL=postgresql://root:SENHA_AQUI@localhost:5432/nextwave_crm?schema=public

