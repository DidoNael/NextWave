# ============================================
# NextWave CRM - Variáveis de Ambiente
# Copie este arquivo para .env e preencha
# ============================================

# URL pública da aplicação (Vazio para detecção automática via AUTH_TRUST_HOST)
# Exemplos: http://192.168.1.100:3010 ou https://crm.meudominio.com.br
NEXTAUTH_URL=
# Chave secreta para sessões (gere uma com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
NEXTAUTH_SECRET=TROQUE-ESTA-CHAVE-POR-UMA-FORTE-DE-32-CHARS
AUTH_SECRET=TROQUE-ESTA-CHAVE-POR-UMA-FORTE-DE-32-CHARS

# Banco de dados PostgreSQL
# Se usar o Docker Compose padrão, use a URL abaixo:
DATABASE_URL=postgresql://root:nextwave_setup_2026@nextwave-db:5432/nextwave_crm?schema=public

# Evolution API - WhatsApp (Gere uma com: openssl rand -base64 32)
EVOLUTION_API_KEY=TROQUE-ESTA-CHAVE-POR-UMA-FORTE
